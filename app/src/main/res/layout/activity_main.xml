<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/backgroundColor"
    android:visibility="visible">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="SMS Listener Demo - Direksiyon Butonları"
        android:textColor="@color/logText"
        android:textSize="18sp"
        android:textStyle="bold"
        android:padding="8dp"
        android:gravity="center"
        android:visibility="visible" />

    <Button
        android:id="@+id/btnClear"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Logları Temizle"
        android:textColor="@color/textPrimary"
        android:backgroundTint="@color/buttonNeutral"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/logPanelBg"
        android:visibility="visible">

        <TextView
            android:id="@+id/tvLogs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎧 Direksiyon butonları dinleniyor...\n\n"
            android:textColor="@color/logText"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:visibility="visible" />
    </ScrollView>

</LinearLayout>
